A) CSV to HORUS Format
Code:
# Import libraries
import pandas as pd
from google.colab import files

# Upload file
uploaded = files.upload()

# Read CSV file
InputData = pd.read_csv('Country_Code.csv', encoding='latin-1')

print("Input Data =======================")
print(InputData)

# Processing
ProcessData = InputData.copy()

# Remove unwanted columns
ProcessData.drop(['ISO-2-CODE', 'ISO-3-Code'], axis=1, inplace=True)

# Rename columns
ProcessData.rename(columns={
    'Country': 'CountryName',
    'ISO-M49': 'CountryNumber'
}, inplace=True)

# Set index
ProcessData.set_index('CountryNumber', inplace=True)

# Sort data
ProcessData.sort_values('CountryName', ascending=False, inplace=True)

print("Processed Data (HORUS) ==========")
print(ProcessData)

print("CSV to HORUS - Done")

