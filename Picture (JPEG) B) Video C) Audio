from pydub import AudioSegment
from scipy.io import wavfile
import pandas as pd
import matplotlib.pyplot as plt

# STEP 3: Convert MP3 → WAV (if needed)
if audio_file.endswith(".mp3"):
    sound = AudioSegment.from_mp3(audio_file)
    wav_file = "converted_audio.wav"
    sound.export(wav_file, format="wav")
else:
    wav_file = audio_file

# STEP 4: Read WAV File
rate, data = wavfile.read(wav_file)

print("Sampling Rate:", rate)
print("Shape:", data.shape)

# STEP 5: Convert to DataFrame
ProcessData = pd.DataFrame(data)

if len(data.shape) > 1:
    ProcessData.columns = [f"Ch{i+1}" for i in range(data.shape[1])]
else:
    ProcessData.columns = ["Ch1"]

# STEP 6: Plot Waveform
plt.figure(figsize=(10,4))
plt.plot(data)
plt.title("Audio Signal")
plt.xlabel("Samples")
plt.ylabel("Amplitude")
plt.show()

# STEP 7: Save to HORUS
ProcessData.to_csv("HORUS_Audio.csv", index=False)
print("✅ Audio to HORUS - Done")
