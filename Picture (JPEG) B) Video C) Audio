# STEP 1: Upload Video
from google.colab import files
uploaded = files.upload()

video_name = list(uploaded.keys())[0]
print("Uploaded file:", video_name)

# STEP 2: Import Libraries
import cv2
import os
import pandas as pd
import numpy as np
from IPython.display import clear_output

# STEP 3: Read Video
video = cv2.VideoCapture(video_name)

if not video.isOpened():
    print("Error: Cannot open video")
    exit()
# Create frames folder
os.makedirs("frames", exist_ok=True)

# STEP 4: Extract Frames (Skip frames for speed)
count = 0
saved_count = 0
while True:
    success, image = video.read()
    if not success:
        break

    # Save only every 5th frame (🔥 speed improvement)
    if count % 5 == 0:
        cv2.imwrite(f"frames/frame_{saved_count}.jpg", image)
        saved_count += 1

    if count % 20 == 0:
        clear_output(wait=True)
        print(f"Extracting frames... {count} processed")

    count += 1

print("Total Frames Extracted:", saved_count)

# STEP 5: Convert Frames → HORUS (FAST)
frames_data = []

files_list = sorted(os.listdir("frames"))

if len(files_list) == 0:
    print("No frames found!")
    exit()

for i, file in enumerate(files_list):

    path = os.path.join("frames", file)
    img = cv2.imread(path)

    if img is None:
        continue

    # 🔥 Resize image (MOST IMPORTANT for speed)
    img = cv2.resize(img, (64, 64))

    data = img.flatten()

    df = pd.DataFrame(
        np.reshape(data, (-1, 3)),
        columns=['Red', 'Green', 'Blue']
    )

    df['FrameName'] = file
    frames_data.append(df)

    if i % 10 == 0:
        clear_output(wait=True)
        print(f"Converting to HORUS... {i} frames processed")

# STEP 6: Save CSV
if frames_data:
    final_data = pd.concat(frames_data, ignore_index=True)
    final_data.to_csv("HORUS_Video.csv", index=False)

    print("✅ Video to HORUS - Completed Successfully")
else:
    print("No data to save!")
